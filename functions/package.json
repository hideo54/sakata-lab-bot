{
  "name": "functions",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "debug": "node --inspect node_modules/.bin/functions-framework --source=lib/ --target=sakataLabBot",
    "deploy": "firebase deploy --only functions",
    "format": "oxfmt",
    "logs": "firebase functions:log",
    "prepare": "cd .. && husky functions/.husky || true"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^5.0.2",
    "@google-cloud/storage": "^7.21.0",
    "@slack/bolt": "^4.7.3",
    "@types/body-parser": "^1.19.6",
    "@types/common-tags": "^1.8.4",
    "body-parser": "^2.2.2",
    "common-tags": "^1.8.2",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "firebase-functions": "^7.2.5",
    "node-ssh": "^13.2.1",
    "scrape-it": "^6.1.2"
  },
  "devDependencies": {
    "@slack/types": "^2.21.1",
    "@types/node": "^25.9.3",
    "@types/ssh2": "^1.15.5",
    "@types/ssh2-streams": "^0.1.13",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": "24"
  }
}
